<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/widget_background">

        <!-- Header Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/widget_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vedic Panchang"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#E0FFFFFF"
                android:textSize="9sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Festival (conditional) -->
        <TextView
            android:id="@+id/widget_festival"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <!-- Premium Divider 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:background="#80FFFFFF" />

        <!-- Tithi Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="🌙 Tithi"
                android:textColor="#E0FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/widget_tithi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Loading..."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />
        </LinearLayout>

        <!-- Nakshatra Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="⭐ Nakshatra"
                android:textColor="#E0FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/widget_nakshatra"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />
        </LinearLayout>

        <!-- Yoga Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="☀ Yoga"
                android:textColor="#E0FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

            <TextView
                android:id="@+id/widget_yoga"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end" />
        </LinearLayout>

        <!-- Premium Divider 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1.5dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#80FFFFFF" />

        <!-- Sunrise / Sunset Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌅 Sunrise"
                    android:textColor="#E0FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.03" />

                <TextView
                    android:id="@+id/widget_sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌇 Sunset"
                    android:textColor="#E0FFFFFF"
                    android:textSize="9sp"
                    android:letterSpacing="0.03"
                    android:gravity="end" />

                <TextView
                    android:id="@+id/widget_sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingTop="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
