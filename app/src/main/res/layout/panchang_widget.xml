<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="11dp"
        android:paddingBottom="10dp"
        android:background="@drawable/widget_background">

        <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Om symbol -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_om_symbol"
                android:textColor="#F4C447"
                android:textSize="26sp"
                android:paddingRight="10dp" />

            <!-- App name + Date + Festival (inline) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Panchang"
                    android:textColor="#80FFF3E0"
                    android:textSize="9sp" />

                <TextView
                    android:id="@+id/widget_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thursday, 29 May"
                    android:textColor="#F4C447"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Festival inline below the date, hidden when none -->
                <TextView
                    android:id="@+id/widget_festival"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFD180"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="1dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Location — right side -->
            <TextView
                android:id="@+id/widget_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#66FFF3E0"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingLeft="6dp"
                android:gravity="end"
                android:visibility="gone" />
        </LinearLayout>

        <!-- GOLD DIVIDER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:background="#40F4C447" />

        <!-- ══ PANCHANG CHIPS — ROW 1: Tithi | Nakshatra ══════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginRight="3dp"
                android:background="@drawable/widget_chip_bg">

                <TextView
                    android:id="@+id/widget_lbl_tithi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tithi"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_tithi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginLeft="3dp"
                android:background="@drawable/widget_chip_bg">

                <TextView
                    android:id="@+id/widget_lbl_nakshatra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nakshatra"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_nakshatra"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="1dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══ PANCHANG CHIPS — ROW 2: Yoga | Karana ══════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginRight="3dp"
                android:background="@drawable/widget_chip_bg">

                <TextView
                    android:id="@+id/widget_lbl_yoga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_yoga"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_marginLeft="3dp"
                android:background="@drawable/widget_chip_bg">

                <TextView
                    android:id="@+id/widget_lbl_karana"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Karana"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_karana"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:paddingTop="1dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- GOLD DIVIDER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="5dp"
            android:background="#40F4C447" />

        <!-- ══ SUN / MOON — ROW 1: Sunrise | Moonrise ══════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:background="@drawable/widget_sun_bg">

            <!-- Sunrise -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_lbl_sunrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunrise"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#127749;"
                        android:textSize="12sp"
                        android:paddingRight="4dp" />

                    <TextView
                        android:id="@+id/widget_sunrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#F4C447"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Vertical separator -->
            <LinearLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#30F4C447" />

            <!-- Moonrise -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_lbl_moonrise"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moonrise"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#127761;"
                        android:textSize="12sp"
                        android:paddingRight="4dp" />

                    <TextView
                        android:id="@+id/widget_moonrise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#D0C8FF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SUN / MOON — ROW 2: Sunset | Moonset ═══════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:layout_marginTop="3dp"
            android:background="@drawable/widget_sun_bg">

            <!-- Sunset -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_lbl_sunset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sunset"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#127751;"
                        android:textSize="12sp"
                        android:paddingRight="4dp" />

                    <TextView
                        android:id="@+id/widget_sunset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#F4C447"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Vertical separator -->
            <LinearLayout
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:background="#30F4C447" />

            <!-- Moonset -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/widget_lbl_moonset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moonset"
                    android:textColor="#99FFF3E0"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9790;"
                        android:textSize="12sp"
                        android:paddingRight="4dp" />

                    <TextView
                        android:id="@+id/widget_moonset"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textColor="#D0C8FF"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- GOLD DIVIDER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:background="#40F4C447" />

        <!-- ══ VAAR — full-width bottom row ════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="@drawable/widget_chip_bg">

            <TextView
                android:id="@+id/widget_lbl_vaar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vaar"
                android:textColor="#99FFF3E0"
                android:textSize="11sp"
                android:paddingRight="10dp" />

            <TextView
                android:id="@+id/widget_vaar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--"
                android:textColor="#F4C447"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>
</FrameLayout>
